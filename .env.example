# Copy this file to .env and fill in your keys.
# Never commit your real .env file.

# Required: get this from https://console.anthropic.com
ANTHROPIC_API_KEY=

# Optional: upgrade Maku's Call voice from the free browser TTS to ElevenLabs.
# Leave ELEVENLABS_API_KEY blank to keep the free browser voice.
ELEVENLABS_API_KEY=
# Paste the Voice ID of the ElevenLabs voice you want Maku to use.
# (ElevenLabs → Voices → a voice → "ID"). Defaults to the "Rachel" preset.
ELEVENLABS_VOICE_ID=
# Model: eleven_flash_v2_5 (fast, cheapest) | eleven_turbo_v2_5 | eleven_multilingual_v2
ELEVENLABS_MODEL=eleven_flash_v2_5

PORT=3000
